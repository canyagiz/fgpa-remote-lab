# Generated by the provisioning wizard for {{ inventory_hostname }}.
# Describes THIS shuttle's physical hardware - not portable. Do not commit.
# docker-compose.yml in the hardware repo reads these values.

# --- Intel Quartus programmer (Cyclone boards only) ---
INTELFPGA_DIR={{ intelfpga_dir }}
QUARTUS_BIN_DIR={{ quartus_bin_dir }}

# --- USB / video device paths (from the "detected devices" step) ---
USB_BLASTER_DEVICE={{ device_map.usb_blaster | default('/dev/usb-blaster') }}
MAGEWELL_DEVICE={{ device_map.magewell | default('/dev/magewell') }}
VIDEO0_DEVICE={{ device_map.video0 | default('/dev/video0') }}
VIDEO1_DEVICE={{ device_map.video1 | default('/dev/video1') }}
ARTY_USB_BUS={{ device_map.arty_usb_bus | default('/dev/bus/usb') }}

# --- Board UART bridges (host:port per board on this shuttle) ---
{% for board, uart in (board_uart | default({})).items() %}
{{ board | upper }}_UART_HOST={{ uart.host }}
{{ board | upper }}_UART_PORT={{ uart.port }}
{% endfor %}
