# /etc/nginx/sites-available/fpga-remote-lab
#
# GENERATED - do not hand-edit. Rendered from this template by
# deploy/generate_nginx_config.py, using backend/labs.yaml as the single
# source of truth for which labs exist and where their hardware lives.
# To change a lab's port/host, or add/remove a lab, edit labs.yaml and
# re-run that script - editing this file directly will be overwritten
# next time someone does.
#
# Fronts the FastAPI app (listening on 127.0.0.1:8001, not public) and
# reverse-proxies hardware-lab traffic directly to the boards, mirroring
# what CT200's own nginx does - see [[project_ct210_migration_plan]] for
# the "why" (the container's own url_for()/AJAX calls only resolve
# correctly against whatever origin the browser is on; a bare redirect
# to the board's host:port breaks them, and the two hardcoded
# /labfiles/... image tags live on a *different* container entirely).
#
# Note: every "Host" header below uses $http_host, not $host - nginx's
# $host always strips the port, so our app's request.base_url (used to
# build the proxied hardware URL handed back to the browser) would come
# out missing the port and everything after would 404 against nginx's
# own default site instead. $http_host preserves whatever the client
# actually sent.
map $lab_id $ct300_upstream {
    default        "";
{% for lab in labs %}
    {{ lab.id }}              {{ lab.upstream }}; # {{ lab.name }}
{% endfor %}
}

server {
    listen 8000;
    listen [::]:8000;
    server_name _;

    client_max_body_size 20m;

    # The in-lab "Log out" button must reach our own app, not the board
    # directly - closing the matching reservation the instant logout
    # succeeds needs our database. Must be listed before the general
    # /hw/ location below: nginx tries regex locations in the order
    # they appear in the file and uses the first match.
    location ~ ^/hw/\d+/logout$ {
        proxy_pass http://127.0.0.1:8001;
        proxy_set_header Host $http_host;
        # Append to whatever X-Forwarded-For the host's own edge nginx
        # already set (the real browser IP), rather than overwriting it
        # with $remote_addr - at this hop $remote_addr is the *host's*
        # nginx, not the browser, so overwriting here would collapse
        # every real visitor down to one shared IP for anything that
        # reads this header downstream (see the same fix on the SPA/api
        # location below - that one is what login/register rate
        # limiting actually depends on).
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # The two hardcoded absolute image tags in the lab templates (not
    # generated via url_for, so the X-Forwarded-Prefix trick below
    # doesn't touch them) - served by a separate static-file nginx.
    location ^~ /labfiles/ {
        proxy_pass http://{{ labfiles_host }}/labfiles/;
        proxy_set_header Host {{ labfiles_host }};
    }

    # Everything else for a given lab's hardware container. Setting
    # X-Forwarded-Prefix works without any HTML/JS rewriting because the
    # container's own wsgi wrapper already runs ProxyFix with
    # x_prefix=1 (see wsgi_app_patched.py on CT300) - every url_for()
    # generated link, redirect, and AJAX URL comes back pre-prefixed
    # with /hw/{lab_id} automatically.
    location ~ ^/hw/(?<lab_id>\d+)/(?<rest>.*)$ {
        if ($ct300_upstream = "") {
            return 404;
        }
        proxy_pass http://$ct300_upstream/$rest$is_args$args;
        proxy_set_header Host $http_host;
        proxy_set_header X-Forwarded-Host $http_host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Prefix /hw/$lab_id;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        # The MJPEG video feed is a long-lived streaming response -
        # buffering it would delay frames until nginx's buffer fills.
        proxy_buffering off;
        proxy_read_timeout 300s;
    }

    # The wizard uploads a Quartus installer (multi-GB) the portal then
    # scps to the shuttle. This one path lifts the body limit and streams
    # straight through instead of buffering the whole upload to disk
    # first. Before the SPA location so this regex wins.
    location ~ ^/api/admin/fleet/shuttles/[0-9]+/upload-installer$ {
        client_max_body_size 4g;
        proxy_request_buffering off;
        proxy_pass http://127.0.0.1:8001;
        proxy_set_header Host $http_host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Everything else: the SPA and /api/* - our own FastAPI app.
    location / {
        proxy_pass http://127.0.0.1:8001;
        proxy_set_header Host $http_host;
        # Append, don't overwrite: the host's own edge nginx already put
        # the real browser IP in this header (proxy_add_x_forwarded_for
        # there too) - setting it to bare $remote_addr at this second hop
        # would replace that with the *host's* own address, so every
        # request FastAPI sees would appear to come from the same place
        # regardless of which real visitor sent it. That silently broke
        # the login/register rate limiters (app/routers/auth.py), which
        # key off request.client.host - uvicorn is started with
        # --proxy-headers (see fpga-remote-lab.service) specifically to
        # trust this header from its localhost peer and use it instead.
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
